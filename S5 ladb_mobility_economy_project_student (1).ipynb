   "source": [
    "# Calcular los  promedios de trafico por ciudad, país y año\n",
    "traffic_metrics = ['jams_delay', 'traffic_index_live', 'jams_length_Kms', \n",
    "                   'jams_count', 'mins_delay', 'travel_time_live_per_10kms_mins', \n",
    "                   'travel_time_historic_per_10kms_mins']\n",
    "traffic_city_year_2024 = (traffic.groupby(['City', 'country', 'year'])[traffic_metrics].mean().reset_index())\n",
    "\n",
    "# Mostrar resultado\n",
    "traffic_city_year_2024.head()"
   ]
